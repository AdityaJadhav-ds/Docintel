/**
 * ExtractionStudio.jsx — Phase 3 Document Renderer V2
 *
 * Render Modes:
 *   PAPER     — formatted blocks on white paper (Phase 1/2 style)
 *   SIDEBYSIDE — original image | reconstructed document, linked scroll
 *   ABSOLUTE  — blocks positioned at real coordinates (digital twin)
 *   OVERLAY   — text SVG overlay on original image
 *
 * Phase 3 additions:
 *   - Render mode selector in toolbar
 *   - Side-by-side with synchronized scroll
 *   - Absolute positioning respecting real block coordinates
 *   - Document DNA chip (detected type + evidence)
 *   - Layout graph metadata (column count, section count)
 *   - Quality Engine V2 weighted breakdown
 *   - Smart garbage filter badge
 *   - Multi-pass OCR chain display
 *   - Extended region types in overlay (stamp=red, signature=violet, photo=gray)
 */

import React, { useState, useRef, useCallback, useEffect, useMemo } from 'react';

const API_BASE = '';
const FONT_URL  = 'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Serif:wght@400;700&family=Fira+Code:wght@400;500&display=swap';

// ── Region type colors (extended Phase 3) ─────────────────────────────────────
const REGION_COLORS = {
  table:           { stroke: '#2563eb', fill: 'rgba(37,99,235,0.15)',  label: 'TABLE'   },
  paragraph:       { stroke: '#16a34a', fill: 'rgba(22,163,74,0.12)',  label: 'PARA'    },
  form_field:      { stroke: '#ea580c', fill: 'rgba(234,88,12,0.15)',  label: 'FORM'    },
  header:          { stroke: '#0891b2', fill: 'rgba(8,145,178,0.15)',  label: 'HEADER'  },
  document_header: { stroke: '#0891b2', fill: 'rgba(8,145,178,0.15)',  label: 'DHEADER' },
  section_header:  { stroke: '#7c3aed', fill: 'rgba(124,58,237,0.12)', label: 'SECTION' },
  footer:          { stroke: '#64748b', fill: 'rgba(100,116,139,0.10)',label: 'FOOTER'  },
  handwritten:     { stroke: '#7c3aed', fill: 'rgba(124,58,237,0.15)', label: 'HW'      },
  handwriting:     { stroke: '#7c3aed', fill: 'rgba(124,58,237,0.15)', label: 'HW'      },
  signature:       { stroke: '#a21caf', fill: 'rgba(162,28,175,0.15)', label: 'SIG'     },
  stamp:           { stroke: '#dc2626', fill: 'rgba(220,38,38,0.15)',  label: 'STAMP'   },
  photo:           { stroke: '#78716c', fill: 'rgba(120,113,108,0.12)',label: 'PHOTO'   },
  barcode:         { stroke: '#0f766e', fill: 'rgba(15,118,110,0.15)', label: 'BC'      },
  annotation:      { stroke: '#d97706', fill: 'rgba(217,119,6,0.12)',  label: 'NOTE'    },
  watermark:       { stroke: '#e2e8f0', fill: 'rgba(226,232,240,0.08)',label: 'WM'      },
};

const GRADE_COLORS = { A: '#16a34a', B: '#2563eb', C: '#d97706', D: '#dc2626', F: '#7c3aed' };
const DNA_ICONS = {
  aadhaar: '🪪', pan: '💳', bank_statement: '🏦', invoice: '🧾',
  marksheet: '📊', ration_card: '🗂️', government_doc: '🏛️', passport: '📘', unknown: '📄',
};

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
function gc(g) { return GRADE_COLORS[g] || '#64748b'; }

// ── Global CSS injection ───────────────────────────────────────────────────────
function injectStyles() {
  if (document.getElementById('es-p3-styles')) return;
  const style = document.createElement('style');
  style.id = 'es-p3-styles';
  style.textContent = `
    .es-scroll-sync { overflow-y: auto; }
    .es-paper-block:hover { outline: 1px solid rgba(37,99,235,0.3); }
    .es-abs-block { position: absolute; overflow: hidden; cursor: default; }
    .es-abs-block:hover { outline: 2px solid rgba(37,99,235,0.5); z-index: 10; }
    .es-overlay-text { pointer-events: none; }
    .es-link-scroll { scroll-behavior: smooth; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .es-spinner { animation: spin 0.8s linear infinite; }
    .es-tab-active { border-bottom: 2px solid #2563eb !important; color: #2563eb !important; font-weight: 600 !important; }
    .es-quality-bar { height: 3px; border-radius: 2px; transition: width 0.4s ease; }
    .es-chip { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; white-space: nowrap; }
    .es-region-label { font: bold 8px/10px monospace; fill: white; }
  `;
  document.head.appendChild(style);
}

// ── Shared Layout ──────────────────────────────────────────────────────────────
